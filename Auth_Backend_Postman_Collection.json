              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"PASTE_FACEBOOK_ACCESS_TOKEN_FROM_FLUTTER_HERE\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/oauth2/facebook",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
